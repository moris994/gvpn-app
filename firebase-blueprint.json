{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Stores user account details and VPN preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique identifier from Firebase Auth" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "displayName": { "type": "string", "description": "User's display name" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" },
        "subscriptionStatus": { "type": "string", "enum": ["free", "premium"], "description": "User's subscription level" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "users",
      "description": "User profile documents"
    }
  }
}
